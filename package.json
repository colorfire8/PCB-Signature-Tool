{
	"name": "pcb-signature-tool",
	"version": "1.0.0",
	"description": "为 PCB 丝印生成并插入作者签名信息（二维码/仓库/版本/协议/致谢/手写签名）",
	"author": "Colorfire",
	"license": "Apache-2.0",
	"homepage": "https://github.com/colorfire8/PCB-Signature-Tool",
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"compile": "rimraf ./dist/ && ts-node ./config/esbuild.prod.ts",
		"lint": "eslint",
		"fix": "eslint --fix",
		"build": "npm run compile && ts-node ./build/packaged.ts"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.2.13",
		"@types/fs-extra": "^11.0.4",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jszip": "^3.10.1",
		"lint-staged": "^16.2.3",
		"rimraf": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
